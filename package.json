    "expo": "^56.0.11",
    "expo-asset": "~56.0.17",
    "expo-calendar": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-crypto": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-sharing": "~56.0.17",
    "expo-sqlite": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
