{
  "name": "tutor-log-app",
  "version": "0.1.0",
  "private": true,
  "description": "Tutoring CRM",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo run:ios",
